generator client {
  provider = "prisma-client-js"
}

// Local dev uses SQLite (DATABASE_URL=file:./dev.db). On Render we swap
// this to `postgresql` at build time via scripts/prepare-postgres-schema.mjs.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NOTE: SQLite doesn't support native enums or array columns. We use
// validated string literals at the app boundary (see lib/validation.ts) and
// JSON-serialize tag arrays via the `tags` field in `Task`.

model Task {
  id          String   @id @default(cuid())
  notionId    String?  @unique
  title       String
  description String?
  type        String   @default("TASK") // EPIC | TASK | ISSUE
  status      String   @default("TODO") // TODO | IN_PROGRESS | BLOCKED | DONE
  startDate   DateTime
  endDate     DateTime
  progress    Int      @default(0)

  parentId String?
  parent   Task?   @relation("Hier", fields: [parentId], references: [id], onDelete: SetNull)
  children Task[]  @relation("Hier")
  linkedTaskId String?
  linkedTask   Task?  @relation("IssueLink", fields: [linkedTaskId], references: [id], onDelete: SetNull)
  linkedIssues Task[] @relation("IssueLink")

  dependsOn  Dependency[] @relation("Dependent")
  dependedBy Dependency[] @relation("Predecessor")

  assignee String?
  resourceAllocated String?
  effortHours Int?
  tags     String  @default("[]") // JSON-encoded string[]

  // Execution fields used by the master task list at /tasks. `priority`,
  // `blocked`, and `nextStep` are editable from the task drawer; `health`
  // and `lastProgressAt` are server-computed whenever a progress snapshot
  // is written (see app/api/tasks/[id]/progress).
  priority        String?    // high | medium | low (falls back to tags urgency:* for legacy rows)
  remainingEffort Int?
  blocked         Boolean    @default(false)
  nextStep        String?
  health          String?    // green | yellow | red (cached; recomputed on every progress write)
  lastProgressAt  DateTime?

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updates   TaskUpdate[]

  @@index([parentId])
  @@index([linkedTaskId])
  @@index([type])
  @@index([status])
  @@index([assignee])
  @@index([lastProgressAt])
}

model TaskUpdate {
  id String @id @default(cuid())
  taskId String
  commentType String @default("PROGRESS") // PROGRESS | OPEN_ISSUE
  comment String
  progress Int?
  endDate DateTime?
  effortHours Int?
  assignee String?
  resourceAllocated String?
  // Snapshot-driven execution fields. Written by /api/tasks/[id]/progress so
  // /burndown and the history drawer can reconstruct any task's trajectory.
  remainingEffort Int?
  status          String?
  blocked         Boolean?
  health          String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([createdAt])
}

model Dependency {
  id            String @id @default(cuid())
  predecessorId String
  dependentId   String
  type          String @default("FS") // FS | SS | FF | SF
  lagDays       Int    @default(0)

  predecessor Task @relation("Predecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  dependent   Task @relation("Dependent", fields: [dependentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([predecessorId, dependentId])
  @@index([predecessorId])
  @@index([dependentId])
}

model SyncLog {
  id       String   @id @default(cuid())
  source   String   @default("notion")
  runAt    DateTime @default(now())
  imported Int      @default(0)
  skipped  Int      @default(0)
  failed   Int      @default(0)
  errors   String?
  message  String?
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Individual contributors available to assign to Tasks. Used as the roster
// for the People page + resource matrix. Task assignments still live on
// Task.assignee and Task.resourceAllocated as free-form strings so Notion
// imports and ad-hoc names keep working; the matrix matches those strings
// against Person.name (case-insensitive).
model Person {
  id        String   @id @default(cuid())
  name      String   @unique
  role      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}
