# Local DB is SQLite (file in ./prisma/dev.db). Zero setup.
# For Postgres in production (e.g. Render), change the provider in
# prisma/schema.prisma and set DATABASE_URL to a postgres:// URL.
DATABASE_URL="file:./dev.db"

# Notion integration (can also be set via the Settings page)
# Create an internal integration at https://www.notion.so/my-integrations
# and share the two databases with it.
NOTION_TOKEN=""
NOTION_ROADMAP_DB_ID=""
NOTION_ISSUES_DB_ID=""

# Basic auth for deployed app. Leave empty to disable (local dev).
# Username is fixed to "admin".
APP_PASSWORD=""
